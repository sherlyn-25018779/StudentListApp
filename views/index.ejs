<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student List App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Student List App</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-secondary" href="/student">Add new student</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <h2 class="text-center mb-4 fw-semibold text-secondary-emphasis">Students from Student List App Database</h2>
        
        <div class="card shadow-sm border-0">
            <div class="table-responsive p-3">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th scope="col" class="ps-4">Student Name</th>
                            <th scope="col">Student Image</th>
                            <th scope="col">Dob</th>
                            <th scope="col">Contact</th>
                            <th scope="col" class="pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(students.length > 0) { %>
                            <% students.forEach(student => { %>
                                <tr>
                                    <td class="ps-4">
                                        <a href="/student/<%= student.studentId %>" class="text-decoration-none fw-medium text-primary">
                                            <%= student.name %>
                                        </a>
                                    </td>
                                    <td>
                                        <img src="/uploads/<%= student.image %>" alt="<%= student.name %>" class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover;">
                                    </td>
                                    <td><%= formatDate(student.dob) %></td>
                                    <td class="text-muted"><%= student.contact %></td>
                                    <td class="pe-4">
                                        <div class="d-flex gap-2">
                                            <a href="/student/<%= student.studentId %>" class="btn btn-sm btn-outline-primary">View</a>
                                            <a href="/student/<%= student.studentId %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                                            <form action="/student/<%= student.studentId %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this student?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No student records found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>