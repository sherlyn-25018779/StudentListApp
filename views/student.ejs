<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= student.name %> - Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Student List App</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-secondary" href="/student">Add new student</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                
                <a href="/" class="btn btn-sm btn-outline-secondary mb-3">← Back to Student List</a>
                
                <div class="card border-0 shadow-sm text-center p-4">
                    <div class="my-3">
                        <img src="<%= student.image %>" alt="<%= student.name %>" class="rounded-circle border border-secondary-subtle p-1 shadow-sm" style="width: 140px; height: 140px; object-fit: cover;">
                    </div>
                    
                    <div class="card-body">
                        <h3 class="card-title fw-bold text-secondary-emphasis mb-1"><%= student.name %></h3>
                        <p class="text-muted mb-4">Student ID: #<%= student.studentId %></p>
                        
                        <hr class="text-muted my-3">
                        
                        <div class="row text-start my-3">
                            <div class="col-5 text-muted fw-semibold small">Date of Birth:</div>
                            <div class="col-7 text-dark fw-medium"><%= formatDate(student.dob) %></div>
                        </div>
                        <div class="row text-start my-3">
                            <div class="col-5 text-muted fw-semibold small">Contact Number:</div>
                            <div class="col-7 text-dark fw-medium"><%= student.contact %></div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>