<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Student List App</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-secondary" href="/student">Add new student</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-sm p-4">
                    <h2 class="text-center mb-4 fw-semibold text-secondary-emphasis">Add New Student</h2>
                    
                    <form action="/student" method="POST">
                        <div class="mb-3">
                            <label for="name" class="form-label text-muted small fw-bold">Student Name:</label>
                            <input type="text" class="form-control" id="name" name="name" required placeholder="e.g. Anne John">
                        </div>
                        
                        <div class="mb-3">
                            <label for="dob" class="form-label text-muted small fw-bold">D.o.B:</label>
                            <input type="date" class="form-control" id="dob" name="dob" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="contact" class="form-label text-muted small fw-bold">Contact:</label>
                            <input type="text" class="form-control" id="contact" name="contact" maxlength="10" required placeholder="e.g. 87654321">
                        </div>
                        
                        <div class="mb-4">
                            <label for="image" class="form-label text-muted small fw-bold">Image URL:</label>
                            <input type="url" class="form-control" id="image" name="image" required placeholder="https://images.unsplash.com/...">
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-outline-dark fw-semibold py-2">Add Student</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>